# ============================================================
# Voice AI Agent - Environment Variables
# Copy this file to `.env` and fill in your keys.
# ============================================================

# ---------- Telephony (Twilio) ----------
# Sign up: https://www.twilio.com/try-twilio  (free trial: $15 credit, no card upgrade needed)
# Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Set true in production to reject any webhook missing or failing X-Twilio-Signature.
# Keep false during local development so ngrok URL rewrites don't block testing.
ENFORCE_TWILIO_SIGNATURE=false

# ---------- Speech-to-Text (Deepgram) ----------
# Sign up: https://console.deepgram.com/signup  ($200 free credit, no card)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ---------- LLM (Groq) ----------
# Sign up: https://console.groq.com  (free tier, no card)
GROQ_API_KEY=gsk_your_groq_key_here

# ---------- Provider routing (swappable via env) ----------
STT_PROVIDER=deepgram
LLM_PROVIDER=groq
TTS_PROVIDER=deepgram
TELEPHONY_PROVIDER=twilio

# ---------- Model selection ----------
GROQ_MODEL=llama-3.3-70b-versatile
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ---------- Public URL (ngrok during dev) ----------
# Twilio needs a public URL to reach your local FastAPI.
# Start ngrok: `ngrok http 8000`, then paste the https URL here.
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# ---------- Safety / cost guardrails ----------
MAX_CALLS_PER_HOUR=20
MAX_TURNS_PER_CALL=12
CALL_MAX_DURATION_SECONDS=300

# ---------- Mode flags ----------
STREAMING_MODE=true               # false = Twilio <Gather>/<Say> turn-based fallback
ANSWERING_MACHINE_DETECTION=true
LOG_LEVEL=INFO
